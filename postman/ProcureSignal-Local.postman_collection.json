{
  "info": {
    "_postman_id": "d2d2fdcf-6c70-4f31-bfdb-1c0fbcc4f1b4",
    "name": "ProcureSignal Local",
    "description": "Local development collection for ProcureSignal API endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        }
      },
      "response": []
    },
    {
      "name": "List Signals",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/signals?skip=0&limit=50",
          "host": ["{{baseUrl}}"],
          "path": ["api", "signals"],
          "query": [
            {
              "key": "skip",
              "value": "0"
            },
            {
              "key": "limit",
              "value": "50"
            },
            {
              "key": "signal_type",
              "value": "",
              "disabled": true
            },
            {
              "key": "severity",
              "value": "",
              "disabled": true
            },
            {
              "key": "entity_id",
              "value": "{{entityId}}",
              "disabled": true
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "Signal Stats Summary",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/signals/stats/summary",
          "host": ["{{baseUrl}}"],
          "path": ["api", "signals", "stats", "summary"]
        }
      },
      "response": []
    },
    {
      "name": "Get Signal By ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/signals/{{signalId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "signals", "{{signalId}}"]
        }
      },
      "response": []
    },
    {
      "name": "Get Entity Signals",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/signals/entity/{{entityId}}/signals",
          "host": ["{{baseUrl}}"],
          "path": ["api", "signals", "entity", "{{entityId}}", "signals"]
        }
      },
      "response": []
    },
    {
      "name": "Acknowledge Signal",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/signals/{{signalId}}/acknowledge",
          "host": ["{{baseUrl}}"],
          "path": ["api", "signals", "{{signalId}}", "acknowledge"]
        }
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "signalId",
      "value": ""
    },
    {
      "key": "entityId",
      "value": ""
    }
  ]
}
