# Database
DATABASE_URL=postgresql+asyncpg://procuresignal:procuresignal@postgres:5432/procuresignal
SQLALCHEMY_ECHO=false
POSTGRES_HOST_PORT=5434

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_HOST_PORT=6380

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# API
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
ENABLE_APSCHEDULER=false

# Worker
WORKER_CONCURRENCY=4

# LLM
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano

# News APIs
NEWSAPI_KEY=
GDELT_ENABLED=false

# Registry source overrides (true/false only). Defaults mirror sources-v1.
SOURCE_EU_COMMISSION_PRESS_ENABLED=true
SOURCE_EU_COUNCIL_PRESS_ENABLED=false
SOURCE_ECB_PRESS_ENABLED=true
# Intentionally disabled: requires secret query injection and exceeds the 5 MiB fetch ceiling.
SOURCE_EU_FINANCIAL_SANCTIONS_ENABLED=false
SOURCE_EUROSTAT_UPDATES_ENABLED=true
SOURCE_FREIGHTWAVES_ENABLED=false
SOURCE_MINING_COM_ENABLED=true
SOURCE_OILPRICE_ENABLED=true
SOURCE_SUPPLY_CHAIN_DIVE_ENABLED=true
SOURCE_DW_BUSINESS_ENABLED=true

# Frontend (browser-facing; point at the host-published API)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
